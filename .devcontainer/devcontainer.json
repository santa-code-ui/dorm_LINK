{
  "name": "dorm_LINK Dev Environment",
  "image": "mcr.microsoft.com/devcontainers/java:21",
  "features": {
    "ghcr.io/devcontainers/features/mysql:1": {
      "version": "latest",
      "rootPassword": "root"
    }
  },
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": { "label": "dorm_LINK App", "onAutoForward": "openBrowser" }
  },
  "postCreateCommand": "bash .devcontainer/setup-codespace.sh",
  "customizations": {
    "vscode": {
      "extensions": ["vscjava.vscode-java-pack", "mtxr.sqltools"]
    }
  }
}
